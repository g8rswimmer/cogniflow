# ─────────────────────────────────────────────────────────────────────────────
# cogniflow — environment variables
# Copy this file to .env and fill in the required values before running.
# Lines starting with # are comments. Values without a default MUST be set.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────

# Password for the cogniflow MySQL application user.
MYSQL_PASSWORD=cogniflow_pass

# Root password used by MySQL to initialise the container (not used by the app).
MYSQL_ROOT_PASSWORD=cogniflow_root

# ── Backend (required) ───────────────────────────────────────────────────────

# 32-byte AES-256-GCM key for encrypting sensitive node config values at rest.
# The server refuses to start if this is missing or shorter than 32 bytes.
# Generate a fresh key with:
#   openssl rand -base64 32
COGNIFLOW_ENCRYPTION_KEY=

# ── Backend (optional) ───────────────────────────────────────────────────────

# Log verbosity: debug | info | warn | error  (default: info)
LOG_LEVEL=info

# Comma-separated gRPC addresses for out-of-process node plugins.
# Example: localhost:50051,localhost:50052
PLUGIN_ADDRESSES=

# Base URL of an Ollama instance. When set, Ollama is used for RAG embeddings
# instead of OpenAI. Example: http://localhost:11434
OLLAMA_BASE_URL=

# Origin the browser is allowed to reach the backend from.
# In the default docker-compose setup, nginx proxies everything on the same
# origin, so this is not required. Set it when the frontend and backend are
# on different hosts (e.g. local frontend dev against a remote backend).
COGNIFLOW_ALLOWED_ORIGIN=

# ── Port overrides (Docker Compose) ──────────────────────────────────────────

# Host port the backend is published on (default: 8080).
BACKEND_PORT=8080

# Host port the frontend nginx is published on (default: 3000).
FRONTEND_PORT=3000
